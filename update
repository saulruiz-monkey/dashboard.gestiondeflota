<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard · Gestión de Flota</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0c10;--surface:#111318;--surface2:#181c24;--border:#1e2330;--accent:#00e5a0;--accent2:#0095ff;--accent3:#ff6b35;--accent4:#c77dff;--text:#e8eaf0;--muted:#5a6070;--green:#00e5a0}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--bg);color:var(--text);font-family:'Syne',sans-serif;min-height:100vh;overflow-x:hidden}
.header{background:var(--surface);border-bottom:1px solid var(--border);padding:18px 36px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200}
.header-left{display:flex;align-items:center;gap:14px}
.logo-dot{width:10px;height:10px;background:var(--accent);border-radius:50%;box-shadow:0 0 12px var(--accent);animation:pulse 2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.header h1{font-size:17px;font-weight:800;letter-spacing:.05em;text-transform:uppercase}
.header h1 span{color:var(--accent)}
.header-tag{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--muted);background:var(--surface2);border:1px solid var(--border);padding:4px 10px;border-radius:4px}

/* FILTER BAR */
.filter-bar{background:var(--surface);border-bottom:1px solid var(--border);padding:14px 36px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;position:sticky;top:57px;z-index:100}
.filter-group{display:flex;align-items:center;gap:8px}
.filter-label{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.15em;color:var(--muted);text-transform:uppercase;white-space:nowrap}
.filter-select{background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:11px;padding:6px 10px;outline:none;cursor:pointer;transition:border-color .2s}
.filter-select:focus{border-color:var(--accent)}
.filter-sep{width:1px;height:22px;background:var(--border)}
.reset-btn{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.1em;background:transparent;border:1px solid var(--border);border-radius:6px;color:var(--muted);padding:6px 12px;cursor:pointer;transition:all .15s}
.reset-btn:hover{border-color:var(--accent3);color:var(--accent3)}
.filter-badge{font-family:'JetBrains Mono',monospace;font-size:9px;background:var(--accent);color:#000;padding:2px 7px;border-radius:10px;font-weight:700;display:none}
.filter-badge.visible{display:inline}

.main{padding:28px 36px;max-width:1700px;margin:0 auto}
.section-label{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.2em;color:var(--accent);text-transform:uppercase;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.section-label::after{content:'';flex:1;height:1px;background:var(--border)}

/* KPIs */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:32px}
.kpi-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:22px;position:relative;overflow:hidden;transition:border-color .2s,transform .2s}
.kpi-card:hover{border-color:var(--accent);transform:translateY(-2px)}
.kpi-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.kpi-card:nth-child(1)::before{background:var(--accent)}
.kpi-card:nth-child(2)::before{background:var(--accent2)}
.kpi-card:nth-child(3)::before{background:var(--accent3)}
.kpi-card:nth-child(4)::before{background:var(--accent4)}
.kpi-label{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.15em;color:var(--muted);text-transform:uppercase;margin-bottom:10px}
.kpi-value{font-size:26px;font-weight:800;line-height:1;margin-bottom:4px}
.kpi-card:nth-child(1) .kpi-value{color:var(--accent)}
.kpi-card:nth-child(2) .kpi-value{color:var(--accent2)}
.kpi-card:nth-child(3) .kpi-value{color:var(--accent3)}
.kpi-card:nth-child(4) .kpi-value{color:var(--accent4)}
.kpi-sub{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted)}

/* Charts */
.charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:20px}
.chart-full{grid-column:1/-1}
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;transition:border-color .2s}
.chart-card:hover{border-color:#2a3040}
.chart-title{font-size:14px;font-weight:700;letter-spacing:.03em;margin-bottom:3px}
.chart-sub{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted);margin-bottom:20px}

/* Table shared */
.table-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;overflow:hidden;margin-bottom:20px}
.table-controls{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:10px}
.search-box{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:7px 12px;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:12px;outline:none;width:220px;transition:border-color .2s}
.search-box:focus{border-color:var(--accent)}
.search-box::placeholder{color:var(--muted)}
.sort-btns{display:flex;gap:6px}
.sort-btn{background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--muted);font-family:'JetBrains Mono',monospace;font-size:10px;padding:5px 11px;cursor:pointer;letter-spacing:.1em;transition:all .15s}
.sort-btn.active,.sort-btn:hover{background:var(--accent);color:#000;border-color:var(--accent)}
table{width:100%;border-collapse:collapse}
thead th{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--muted);text-transform:uppercase;text-align:left;padding:9px 14px;border-bottom:1px solid var(--border);cursor:pointer;user-select:none;white-space:nowrap}
thead th:hover{color:var(--accent)}
tbody tr{border-bottom:1px solid #15191f;transition:background .1s}
tbody tr:hover{background:var(--surface2)}
tbody td{padding:10px 14px;font-size:13px}
.td-num{font-family:'JetBrains Mono',monospace;font-size:12px;text-align:right}
.td-cliente{font-weight:600}
.bar-cell{display:flex;align-items:center;gap:8px}
.mini-bar{height:4px;background:var(--accent);border-radius:2px;min-width:2px;opacity:.7}

.tab-row{display:flex;gap:4px;margin-bottom:16px;flex-wrap:wrap}
.tab{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.08em;padding:5px 11px;border-radius:5px;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--muted);transition:all .15s}
.tab.active,.tab:hover{font-weight:600}

/* PIVOT TABLE */
.pivot-wrap{overflow:auto;max-height:600px;border-radius:8px;border:1px solid var(--border)}
.pivot-table{border-collapse:collapse;white-space:nowrap;font-family:'JetBrains Mono',monospace;font-size:11px}
.pivot-table th{background:var(--surface2);border:1px solid var(--border);padding:7px 12px;text-align:center;font-size:9px;letter-spacing:.1em;color:var(--muted);text-transform:uppercase;position:sticky;top:0;z-index:10}
.pivot-table th.row-header{position:sticky;left:0;z-index:20;background:var(--surface2);text-align:left;min-width:140px}
.pivot-table th.group-header{background:#0d1018;font-size:8px;letter-spacing:.15em;color:var(--accent);border-bottom:2px solid var(--accent)}
.pivot-table td{border:1px solid #15191f;padding:6px 12px;text-align:right;color:var(--text)}
.pivot-table td.row-label{position:sticky;left:0;background:var(--surface);font-weight:600;text-align:left;color:var(--text);z-index:5;border-right:1px solid var(--border)}
.pivot-table td.row-label .tipo-badge{font-size:8px;padding:1px 5px;border-radius:3px;margin-left:6px;letter-spacing:.05em;opacity:.7}
.pivot-table td.row-total{background:#0d1018;font-weight:700;color:var(--accent);border-left:2px solid var(--border)}
.pivot-table tr:hover td{background:#13171f}
.pivot-table tr:hover td.row-label{background:#13171f}
.cell-val{color:var(--text)}
.cell-empty{color:#2a3040}
.pivot-table tr.total-row td{background:#0a0e16;font-weight:700;border-top:2px solid var(--border)}
.pivot-table tr.total-row td.row-label{color:var(--accent2);background:#0a0e16}
.pivot-table tr.total-row td.row-total{color:var(--accent);background:#0d1018}

/* Tipo badges */
.b-digital{background:#0095ff22;color:#0095ff;border:1px solid #0095ff44}
.b-mantenimientos{background:#00e5a022;color:#00e5a0;border:1px solid #00e5a044}
.b-licencia{background:#c77dff22;color:#c77dff;border:1px solid #c77dff44}
.b-gestorias{background:#ff6b3522;color:#ff6b35;border:1px solid #ff6b3544}
.b-interno{background:#ffcc0022;color:#ffcc00;border:1px solid #ffcc0044}
.b-sin{background:#5a607022;color:#5a6070;border:1px solid #5a607044}

.footer{text-align:center;padding:22px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted);border-top:1px solid var(--border);margin-top:16px}
@media(max-width:1024px){.kpi-grid{grid-template-columns:repeat(2,1fr)}.charts-grid{grid-template-columns:1fr}.chart-full{grid-column:auto}.main{padding:20px 16px}.filter-bar{padding:12px 16px}}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(4px);z-index:1000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:16px;width:min(560px,92vw);max-height:80vh;display:flex;flex-direction:column;transform:translateY(16px);transition:transform .2s;overflow:hidden}
.modal-overlay.open .modal{transform:translateY(0)}
.modal-header{padding:20px 24px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.modal-header h3{font-size:14px;font-weight:800;letter-spacing:.04em}
.modal-close{background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--muted);width:28px;height:28px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;transition:all .15s}
.modal-close:hover{border-color:var(--accent3);color:var(--accent3)}
.modal-body{padding:16px 24px 24px;overflow-y:auto;flex:1}
.modal-kpi-row{display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap}
.modal-kpi{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:12px 16px;flex:1;min-width:120px}
.modal-kpi .mk-label{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.15em;color:var(--muted);text-transform:uppercase;margin-bottom:4px}
.modal-kpi .mk-val{font-size:18px;font-weight:800}
.modal-list{display:flex;flex-direction:column;gap:6px}
.modal-list-item{display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;font-size:12px;transition:border-color .15s;gap:8px}
.modal-list-item:hover{border-color:var(--accent)}
.modal-list-item .ml-left{display:flex;flex-direction:column;gap:2px}
.modal-list-item .ml-name{font-weight:600}
.modal-list-item .ml-sub{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--muted)}
.modal-list-item .ml-val{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--accent);white-space:nowrap}
.modal-search{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:8px 12px;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:11px;outline:none;margin-bottom:12px;transition:border-color .2s}
.modal-search:focus{border-color:var(--accent)}
.kpi-card{cursor:pointer}
.kpi-hint{font-family:'JetBrains Mono',monospace;font-size:8px;color:var(--muted);margin-top:6px;letter-spacing:.1em;opacity:.6}
/* PROJECTION */
.projection-bar{background:var(--surface);border:1px solid #00e5a033;border-radius:10px;padding:14px 20px;margin-bottom:20px;display:none;align-items:center;gap:16px;flex-wrap:wrap;animation:fadeIn .3s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
.projection-bar.visible{display:flex}
.proj-icon{font-size:20px}
.proj-text{flex:1}
.proj-title{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.15em;color:var(--accent);text-transform:uppercase;margin-bottom:3px}
.proj-detail{font-size:13px;font-weight:600}
.proj-chips{display:flex;gap:8px;flex-wrap:wrap}
.proj-chip{background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:5px 12px;font-family:'JetBrains Mono',monospace;font-size:10px}
.proj-chip span{font-weight:700}
.proj-chip.up span{color:#00e5a0}.proj-chip.down span{color:#ff6b35}.proj-chip.neu span{color:#0095ff}
</style>
</head>
<body>
<div class="header">
  <div class="header-left"><div class="logo-dot"></div><h1>Gestión de <span>Flota</span></h1></div>
  <div class="header-tag">TECNOCONTROL VEHICULAR · 2025–2026</div>
</div>

<!-- FILTER BAR -->
<div class="filter-bar">
  <div class="filter-group">
    <span class="filter-label">Tipo de Cliente</span>
    <select class="filter-select" id="filterTipo" onchange="applyFilters()">
      <option value="">Todos</option>
    </select>
  </div>
  <div class="filter-sep"></div>
  <div class="filter-group">
    <span class="filter-label">Mes Desde</span>
    <select class="filter-select" id="filterMesFrom" onchange="applyFilters()"></select>
  </div>
  <div class="filter-group">
    <span class="filter-label">Hasta</span>
    <select class="filter-select" id="filterMesTo" onchange="applyFilters()"></select>
  </div>
  <div class="filter-sep"></div>
  <div class="filter-group">
    <span class="filter-label">Ítem</span>
    <select class="filter-select" id="filterItem" onchange="applyFilters()">
      <option value="">Todos</option>
    </select>
  </div>
  <div class="filter-sep"></div>
  <button class="reset-btn" onclick="resetFilters()">↺ LIMPIAR</button>
  <span class="filter-badge" id="filterBadge">FILTRADO</span>
</div>

<div class="main">
  <div class="section-label">Indicadores Clave</div>
  <div class="kpi-grid">
    <div class="kpi-card" onclick="openModal('total')"><div class="kpi-label">Monto Total</div><div class="kpi-value" id="kpi-total">—</div><div class="kpi-sub">Item Total acumulado</div><div class="kpi-hint">▸ CLICK PARA DETALLE</div></div>
    <div class="kpi-card" onclick="openModal('promedio')"><div class="kpi-label">Promedio por Registro</div><div class="kpi-value" id="kpi-avg">—</div><div class="kpi-sub">Monto promedio MXN</div><div class="kpi-hint">▸ CLICK PARA DETALLE</div></div>
    <div class="kpi-card" onclick="openModal('clientes')"><div class="kpi-label">Clientes</div><div class="kpi-value" id="kpi-clientes">—</div><div class="kpi-sub">Nombres únicos activos</div><div class="kpi-hint">▸ CLICK PARA DETALLE</div></div>
    <div class="kpi-card" onclick="openModal('items')"><div class="kpi-label">Número total de Items</div><div class="kpi-value" id="kpi-registros">—</div><div class="kpi-sub">Líneas de detalle (filas reales)</div><div class="kpi-hint">▸ CLICK PARA DETALLE</div></div>
    <div class="kpi-card" onclick="openModal('facturas')"><div class="kpi-label">Invoices Únicos</div><div class="kpi-value" id="kpi-facturas">—</div><div class="kpi-sub">Invoice Numbers distintos</div><div class="kpi-hint">▸ CLICK PARA DETALLE</div></div>
  </div>

  <div class="section-label">Tendencia & Desglose</div>
  <div class="projection-bar" id="projectionBar"><div class="proj-icon">📈</div><div class="proj-text"><div class="proj-title" id="projTitle">Proyección</div><div class="proj-detail" id="projDetail"></div></div><div class="proj-chips" id="projChips"></div></div>
  <div class="charts-grid">
    <div class="chart-card chart-full">
      <div class="chart-title">Monto Total por Mes</div>
      <div class="chart-sub" id="monthChartSub">EVOLUCIÓN MENSUAL</div>
      <div style="position:relative;height:240px"><canvas id="chartMonth"></canvas></div>
    </div>
    <div class="chart-card">
      <div class="chart-title">Distribución por Ítem</div>
      <div class="chart-sub">PARTICIPACIÓN EN MONTO TOTAL</div>
      <div style="position:relative;height:260px"><canvas id="chartItem"></canvas></div>
    </div>
    <div class="chart-card">
      <div class="chart-title">Desglose Mensual por Ítem</div>
      <div class="chart-sub">COMPOSICIÓN STACKED</div>
      <div class="tab-row" id="itemFilterTabs"></div>
      <div style="position:relative;height:200px"><canvas id="chartStackedItem"></canvas></div>
    </div>
  </div>

  <div class="section-label">Ranking de Clientes</div>
  <div class="table-card">
    <div class="table-controls">
      <div><div class="chart-title">Totales por Cliente</div><div class="chart-sub">MONTO ITEM TOTAL ACUMULADO</div></div>
      <div style="display:flex;gap:8px;align-items:center">
        <input class="search-box" type="text" id="searchInput" placeholder="Buscar cliente...">
        <div class="sort-btns">
          <button class="sort-btn active" onclick="sortTable('total')">TOTAL ↓</button>
          <button class="sort-btn" onclick="sortTable('promedio')">PROMEDIO</button>
          <button class="sort-btn" onclick="sortTable('registros')">REGISTROS</button>
        </div>
      </div>
    </div>
    <div style="overflow-x:auto">
      <table><thead><tr>
        <th>#</th><th onclick="sortTable('cliente')">CLIENTE</th><th onclick="sortTable('tipo')">TIPO</th>
        <th onclick="sortTable('total')" style="text-align:right">TOTAL MXN</th>
        <th style="text-align:right">PARTICIPACIÓN</th>
        <th onclick="sortTable('promedio')" style="text-align:right">PROMEDIO MXN</th>
        <th onclick="sortTable('registros')" style="text-align:right">REGISTROS</th>
      </tr></thead>
      <tbody id="clientTableBody"></tbody></table>
    </div>
  </div>

  <div class="section-label">Detalle por Ítem</div>
  <div class="table-card">
    <div class="chart-title">Resumen por Tipo de Ítem</div>
    <div class="chart-sub" style="margin-bottom:18px">MONTO, PROMEDIO Y VOLUMEN</div>
    <div style="overflow-x:auto">
      <table><thead><tr>
        <th>#</th><th>ÍTEM</th>
        <th style="text-align:right">TOTAL MXN</th><th style="text-align:right">%</th>
        <th style="text-align:right">PROMEDIO MXN</th><th style="text-align:right">REGISTROS</th>
      </tr></thead>
      <tbody id="itemTableBody"></tbody></table>
    </div>
  </div>

  <div class="section-label">Tabla Cruzada — Cliente × Mes × Ítem</div>
  <div class="table-card">
    <div class="table-controls">
      <div>
        <div class="chart-title">Pivot: Clientes vs Mes + Ítem</div>
        <div class="chart-sub">FILAS = CLIENTES · COLUMNAS = MES + ÍTEM · VALORES = ITEM TOTAL MXN</div>
      </div>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
        <span class="filter-label" style="margin:0">Agrupar por:</span>
        <select class="filter-select" id="pivotGroupBy" onchange="renderPivot()">
          <option value="item">Ítem primero</option>
          <option value="mes">Mes primero</option>
        </select>
        <input class="search-box" type="text" id="pivotSearch" placeholder="Buscar cliente..." style="width:180px" oninput="renderPivot()">
      </div>
    </div>
    <div class="pivot-wrap" id="pivotContainer"></div>
  </div>
</div>
<div class="footer">TECNOCONTROL VEHICULAR · Gestión de Flota Dashboard · Datos al 13 Abr 2026</div>

