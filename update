function getFilters(){
  return{
    tipo:document.getElementById('filterTipo').value,
    mesFrom:document.getElementById('filterMesFrom').value||ALL_MESES[0],
    mesTo:document.getElementById('filterMesTo').value||ALL_MESES[ALL_MESES.length-1],
    item:document.getElementById('filterItem').value
  };
}

function getFilteredPivot(){
  const f=getFilters();
  return RAW.pivot.filter(r=>{
    if(f.tipo&&r.tipo!==f.tipo)return false;
    if(r.mes<f.mesFrom||r.mes>f.mesTo)return false;
    if(f.item&&r.item!==f.item)return false;
    return true;
  });
}

function getFilteredMeses(){
  const f=getFilters();
  return ALL_MESES.filter(m=>m>=f.mesFrom&&m<=f.mesTo);
}
function getFilteredItems(){
  const f=getFilters();
  return f.item?ALL_ITEMS.filter(i=>i===f.item):ALL_ITEMS;
}

function isFiltered(){
  const f=getFilters();
  return f.tipo||f.mesFrom!==ALL_MESES[0]||f.mesTo!==ALL_MESES[ALL_MESES.length-1]||f.item;
}

function resetFilters(){
  document.getElementById('filterTipo').value='';
  document.getElementById('filterMesFrom').value='';
  document.getElementById('filterMesTo').value=ALL_MESES[ALL_MESES.length-1];
  document.getElementById('filterItem').value='';
  applyFilters();
}

// ===================== COMPUTE FROM FILTERED DATA =====================
function computeAggregates(filteredPivot){
  // Totals from pivot (for chart breakdowns)
  const byClient={},byItem={},byMonth={},byMonthItem={};
  const clientTipo={};
  filteredPivot.forEach(r=>{
    clientTipo[r.cliente]=r.tipo;
    if(!byClient[r.cliente])byClient[r.cliente]={total:0};
    byClient[r.cliente].total+=r.total;
    if(!byItem[r.item])byItem[r.item]={total:0};
    byItem[r.item].total+=r.total;
    if(!byMonth[r.mes])byMonth[r.mes]=0;
    byMonth[r.mes]+=r.total;
    const k=r.mes+'||'+r.item;
    if(!byMonthItem[k])byMonthItem[k]=0;
    byMonthItem[k]+=r.total;
  });

  // Get filters to find matching real stats
  const f=getFilters();

  // Real row counts & averages from pre-computed client_stats
  const filteredClientStats={};
  RAW.client_stats.forEach(r=>{
    if(f.tipo&&r.tipo!==f.tipo)return;
    if(!byClient[r.cliente])return; // not in filtered pivot
    filteredClientStats[r.cliente]={
      total:byClient[r.cliente].total, // use filtered total
      promedio:byClient[r.cliente].total, // will compute below
      registros:r.registros, // real count (unfiltered per client — best approx)
      tipo:r.tipo
    };
  });

  // Real registros: count from pivot_counts matching filters
  const realCounts={};
  RAW.pivot_counts.forEach(r=>{
    if(f.tipo&&r.tipo!==f.tipo)return;
    if(r.mes<f.mesFrom||r.mes>f.mesTo)return;
    if(f.item&&r.item!==f.item)return;
    realCounts[r.cliente]=(realCounts[r.cliente]||0)+r.count;
  });

  // Build byClientFull with real registros
  const byClientFull={};
  Object.keys(byClient).forEach(c=>{
    const cnt=realCounts[c]||1;
    byClientFull[c]={total:byClient[c].total,count:cnt,promedio:byClient[c].total/cnt};
  });

  const totalSum=Object.values(byClient).reduce((a,b)=>a+b.total,0);
  const totalCount=Object.values(realCounts).reduce((a,b)=>a+b,0);

  // Real item registros
  const byItemFull={};
  RAW.item_stats.forEach(r=>{
    if(!byItem[r.item])return;
    if(f.item&&r.item!==f.item)return;
    byItemFull[r.item]={total:byItem[r.item].total,count:0,promedio:0};
  });
  RAW.pivot_counts.forEach(r=>{
    if(f.tipo&&r.tipo!==f.tipo)return;
    if(r.mes<f.mesFrom||r.mes>f.mesTo)return;
    if(f.item&&r.item!==f.item)return;
    if(!byItemFull[r.item])byItemFull[r.item]={total:byItem[r.item]?.total||0,count:0};
    byItemFull[r.item].count+=r.count;
  });
  Object.keys(byItemFull).forEach(i=>{
    const cnt=byItemFull[i].count||1;
    byItemFull[i].promedio=byItemFull[i].total/cnt;
  });

  return{byClient:byClientFull,byItem:byItemFull,byMonth,byMonthItem,clientTipo,totalSum,totalCount};
}

