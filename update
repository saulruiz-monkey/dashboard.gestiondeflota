  }
}

function filterModalList(q, listId) {
  const list = document.getElementById(listId);
  if (!list) return;
  list.querySelectorAll('.modal-list-item').forEach(item => {
    item.style.display = item.textContent.toLowerCase().includes(q.toLowerCase()) ? '' : 'none';
  });
}

function closeModal(e) { if (e.target === document.getElementById('modalOverlay')) closeModalBtn(); }
function closeModalBtn() { document.getElementById('modalOverlay').classList.remove('open'); }
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModalBtn(); });

// ===================== PROJECTION =====================
function updateProjection() {
  const f = getFilters();
  const mesFrom = f.mesFrom || ALL_MESES[0];
  const mesTo = f.mesTo || ALL_MESES[ALL_MESES.length-1];
  const bar = document.getElementById('projectionBar');

  // Only show projection when a specific month range is selected (not all)
  const isFiltered = mesFrom !== ALL_MESES[0] || mesTo !== ALL_MESES[ALL_MESES.length-1];
  if (!isFiltered || mesFrom === mesTo) {
    // Single month selected — project based on previous month
    if (mesFrom === mesTo) {
      const idx = ALL_MESES.indexOf(mesFrom);
      if (idx > 0) {
        const prevMes = ALL_MESES[idx - 1];
        const prevTotal = RAW.month_stats.find(m => m.mes === prevMes)?.total || 0;
        const curTotal = RAW.month_stats.find(m => m.mes === mesFrom)?.total || 0;

        if (prevTotal > 0) {
          // Growth rate from last 3 months avg vs prev month
          const last3 = ALL_MESES.slice(Math.max(0, idx-3), idx).map(m => RAW.month_stats.find(x=>x.mes===m)?.total||0);
          const avg3 = last3.length ? last3.reduce((a,b)=>a+b,0)/last3.length : prevTotal;
          const proj = avg3; // projected = 3-month avg
          const diff = proj - prevTotal;
          const pct = prevTotal ? ((diff/prevTotal)*100).toFixed(1) : 0;
          const isUp = diff >= 0;

          document.getElementById('projTitle').textContent = `Proyección para ${mesFrom} · Basada en promedio de ${last3.length} meses anteriores`;
          document.getElementById('projDetail').textContent = `Mes anterior (${prevMes}): ${fmtM(prevTotal)} → Proyectado: ${fmtM(proj)}`;
          document.getElementById('projChips').innerHTML = `
            <div class="proj-chip ${isUp?'up':'down'}"><span>${isUp?'▲':'▼'} ${Math.abs(pct)}%</span> vs mes anterior</div>
            <div class="proj-chip neu"><span>${fmtM(Math.abs(diff))}</span> diferencia estimada</div>
            ${curTotal > 0 ? `<div class="proj-chip neu"><span>${fmtM(curTotal)}</span> facturado actual</div>` : ''}
          `;
          bar.classList.add('visible');
          return;
        }
      }
    }
    bar.classList.remove('visible');
    return;
  }

  // Range selected: show range summary + projection for next month after range
  const lastMesInRange = mesTo;
  const lastIdx = ALL_MESES.indexOf(lastMesInRange);
  const nextMes = ALL_MESES[lastIdx + 1];

  const mesInRange = ALL_MESES.filter(m => m >= mesFrom && m <= mesTo);
  const totalsInRange = mesInRange.map(m => RAW.month_stats.find(x=>x.mes===m)?.total||0);
  const avgRange = totalsInRange.length ? totalsInRange.reduce((a,b)=>a+b,0)/totalsInRange.length : 0;
  const lastTotal = RAW.month_stats.find(m => m.mes === lastMesInRange)?.total || 0;

  if (avgRange === 0) { bar.classList.remove('visible'); return; }

  const proj = avgRange;
  const diff = proj - lastTotal;
  const pct = lastTotal ? ((diff/lastTotal)*100).toFixed(1) : 0;
  const isUp = diff >= 0;

  document.getElementById('projTitle').textContent = nextMes
    ? `Proyección para ${nextMes} · Promedio del rango seleccionado`
    : `Resumen del rango seleccionado`;
  document.getElementById('projDetail').textContent = nextMes
    ? `Promedio mensual del rango: ${fmtM(avgRange)} → Proyectado para ${nextMes}: ${fmtM(proj)}`
    : `Promedio mensual del periodo: ${fmtM(avgRange)}`;
  document.getElementById('projChips').innerHTML = `
    <div class="proj-chip ${isUp?'up':'down'}"><span>${isUp?'▲':'▼'} ${Math.abs(pct)}%</span> vs último mes</div>
    <div class="proj-chip neu"><span>${mesInRange.length}</span> meses en rango</div>
    <div class="proj-chip neu"><span>${fmtM(totalsInRange.reduce((a,b)=>a+b,0))}</span> total periodo</div>
  `;
  bar.classList.add('visible');
}

// INIT
applyFilters();
