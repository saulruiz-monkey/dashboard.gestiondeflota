let chartMonth=null,chartItem=null,stackedChart=null;
let activeItemsSet=new Set(ALL_ITEMS);

function renderCharts(data){
  const agg=computeAggregates(data);
  const filteredMeses=getFilteredMeses();
  const filteredItems=getFilteredItems();

  // KPIs
  const nClientes=Object.keys(agg.byClient).length;
  document.getElementById('kpi-total').textContent=fmtM(agg.totalSum);
  document.getElementById('kpi-avg').textContent=agg.totalCount?fmt(agg.totalSum/agg.totalCount):'$0';
  document.getElementById('kpi-clientes').textContent=nClientes;
  document.getElementById('kpi-registros').textContent=agg.totalCount.toLocaleString('es-MX');
  document.getElementById('kpi-facturas').textContent=RAW.kpis_real.facturas.toLocaleString('es-MX');

  _lastAgg = agg;
  // badge
  document.getElementById('filterBadge').classList.toggle('visible',!!isFiltered());
  updateProjection();

  // Month chart
  const monthLabels=filteredMeses.map(m=>m.replace('20',''));
  const monthTotals=filteredMeses.map(m=>agg.byMonth[m]||0);
  if(chartMonth)chartMonth.destroy();
  const ctxM=document.getElementById('chartMonth').getContext('2d');
  const grad=ctxM.createLinearGradient(0,0,0,240);
  grad.addColorStop(0,'rgba(0,229,160,.3)');grad.addColorStop(1,'rgba(0,229,160,0)');
  chartMonth=new Chart(ctxM,{type:'line',data:{labels:monthLabels,datasets:[{label:'Total MXN',data:monthTotals,borderColor:'#00e5a0',backgroundColor:grad,borderWidth:2.5,pointRadius:4,pointBackgroundColor:'#00e5a0',pointBorderColor:'#0a0c10',pointBorderWidth:2,tension:.4,fill:true}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:'#181c24',borderColor:'#1e2330',borderWidth:1,titleColor:'#5a6070',bodyColor:'#e8eaf0',titleFont:{family:'JetBrains Mono',size:10},bodyFont:{family:'JetBrains Mono',size:12},callbacks:{label:ctx=>' '+fmtM(ctx.raw)}}},scales:{x:{grid:{color:'#1e2330'},ticks:{color:'#5a6070',font:{family:'JetBrains Mono',size:10}}},y:{grid:{color:'#1e2330'},ticks:{color:'#5a6070',font:{family:'JetBrains Mono',size:10},callback:v=>fmtM(v)}}}}});

  // Item donut — use all items present in filtered data
  const donutItems=filteredItems.filter(i=>activeItemsSet.has(i)&&(agg.byItem[i]?.total||0)>0);
  const donutTotals=donutItems.map(i=>agg.byItem[i].total);
  const donutColors=donutItems.map(i=>COLORS[ALL_ITEMS.indexOf(i)%COLORS.length]);
  if(chartItem)chartItem.destroy();
  chartItem=new Chart(document.getElementById('chartItem'),{type:'doughnut',data:{labels:donutItems,datasets:[{data:donutTotals,backgroundColor:donutColors,borderColor:'#0a0c10',borderWidth:3,hoverOffset:8}]},options:{responsive:true,maintainAspectRatio:false,cutout:'62%',plugins:{legend:{position:'right',labels:{color:'#e8eaf0',font:{family:'JetBrains Mono',size:9},padding:8,boxWidth:9}},tooltip:{backgroundColor:'#181c24',borderColor:'#1e2330',borderWidth:1,titleColor:'#5a6070',bodyColor:'#e8eaf0',callbacks:{label:ctx=>{const pct=agg.totalSum?((ctx.raw/agg.totalSum)*100).toFixed(1):'0';return` ${fmtM(ctx.raw)} (${pct}%)`}}}}}});

  // Stacked bar
  renderStackedChart(agg,filteredMeses,filteredItems);
  renderClientTable(agg);
  renderItemTable(agg,filteredItems);
}

function renderStackedChart(agg,filteredMeses,filteredItems){
  if(stackedChart)stackedChart.destroy();
  const activeItemsFiltered=filteredItems.filter(i=>activeItemsSet.has(i));
  const monthLabels=filteredMeses.map(m=>m.replace('20',''));
  const datasets=activeItemsFiltered.map(item=>{
    const color=COLORS[ALL_ITEMS.indexOf(item)%COLORS.length];
    return{label:item,data:filteredMeses.map(mes=>agg.byMonthItem[mes+'||'+item]||0),backgroundColor:color+'cc',borderColor:color,borderWidth:1,borderRadius:2};
  });
  stackedChart=new Chart(document.getElementById('chartStackedItem'),{type:'bar',data:{labels:monthLabels,datasets},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{backgroundColor:'#181c24',borderColor:'#1e2330',borderWidth:1,titleColor:'#5a6070',bodyColor:'#e8eaf0',callbacks:{label:ctx=>` ${ctx.dataset.label}: ${fmtM(ctx.raw)}`}}},scales:{x:{stacked:true,grid:{color:'#1e2330'},ticks:{color:'#5a6070',font:{family:'JetBrains Mono',size:10}}},y:{stacked:true,grid:{color:'#1e2330'},ticks:{color:'#5a6070',font:{family:'JetBrains Mono',size:10},callback:v=>fmtM(v)}}}}});
}

