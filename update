            </div>
            <div class="ml-val">${fmtM(v.total)}</div>
          </div>`;
        }).join('')}
      </div>`;

  } else if (type === 'facturas') {
    title.textContent = 'Resumen de Invoices';
    const byMes = {};
    RAW.pivot.forEach(r => {
      const f = getFilters();
      if (f.tipo && r.tipo !== f.tipo) return;
      if (r.mes < f.mesFrom || r.mes > f.mesTo) return;
      if (f.item && r.item !== f.item) return;
      byMes[r.mes] = (byMes[r.mes]||0) + r.total;
