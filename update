ALL_ITEMS.forEach((item,i)=>{
  const tab=document.createElement('button');
  tab.className='tab active';tab.textContent=item;
  tab.style.background=COLORS[i%COLORS.length];tab.style.color='#000';tab.style.borderColor=COLORS[i%COLORS.length];
  tab.addEventListener('click',()=>{
    if(activeItemsSet.has(item)){if(activeItemsSet.size===1)return;activeItemsSet.delete(item);tab.classList.remove('active');tab.style.background='';tab.style.color=COLORS[i%COLORS.length];}
    else{activeItemsSet.add(item);tab.classList.add('active');tab.style.background=COLORS[i%COLORS.length];tab.style.color='#000';}
    const filtered=getFilteredPivot();
    const agg=computeAggregates(filtered);
    renderStackedChart(agg,getFilteredMeses(),getFilteredItems());
  });
  tabRow.appendChild(tab);
});

// ===================== CLIENT TABLE =====================
let clientSortKey='total',clientSortDir=-1;
function renderClientTable(agg){
  const q=document.getElementById('searchInput').value.toLowerCase();
  let rows=Object.entries(agg.byClient).map(([c,v])=>({cliente:c,tipo:agg.clientTipo[c]||'',total:v.total,promedio:v.total/v.count,registros:v.count}));
  rows=rows.filter(r=>r.cliente.toLowerCase().includes(q));
  rows.sort((a,b)=>clientSortDir*(a[clientSortKey]>b[clientSortKey]?1:a[clientSortKey]<b[clientSortKey]?-1:0));
  const maxT=Math.max(...rows.map(r=>r.total),1);
  const grandT=agg.totalSum||1;
  document.getElementById('clientTableBody').innerHTML=rows.map((r,i)=>{
    const pct=(r.total/grandT*100).toFixed(1);
    const barW=Math.round((r.total/maxT)*110);
    const bc=TIPO_BADGE[r.tipo]||'b-sin';
    return`<tr><td class="td-num" style="color:var(--muted)">${i+1}</td><td class="td-cliente">${r.cliente}</td><td><span class="badge ${bc}">${r.tipo||'—'}</span></td><td class="td-num" style="color:var(--accent)">${fmtM(r.total)}</td><td><div class="bar-cell"><div class="mini-bar" style="width:${barW}px"></div><span style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--muted)">${pct}%</span></div></td><td class="td-num" style="color:var(--accent2)">${fmt(r.promedio)}</td><td class="td-num">${r.registros.toLocaleString('es-MX')}</td></tr>`;
  }).join('');
}

function sortTable(key){
  if(clientSortKey===key)clientSortDir*=-1;else{clientSortKey=key;clientSortDir=-1;}
  document.querySelectorAll('.sort-btn').forEach(b=>b.classList.remove('active'));
  const filtered=getFilteredPivot();renderClientTable(computeAggregates(filtered));
}
document.getElementById('searchInput').addEventListener('input',()=>{const filtered=getFilteredPivot();renderClientTable(computeAggregates(filtered));});

// ===================== ITEM TABLE =====================
function renderItemTable(agg,filteredItems){
  const totalSum=filteredItems.reduce((s,i)=>s+(agg.byItem[i]||0),0)||1;
  document.getElementById('itemTableBody').innerHTML=filteredItems.map((item,i)=>{
    const v=agg.byItem[item]||{total:0,count:0};
    const pct=((v.total||0)/totalSum*100).toFixed(1);
    const color=COLORS[ALL_ITEMS.indexOf(item)%COLORS.length];
    return`<tr><td class="td-num" style="color:var(--muted)">${i+1}</td><td><span style="display:inline-block;width:8px;height:8px;background:${color};border-radius:2px;margin-right:8px"></span>${item}</td><td class="td-num" style="color:${color}">${fmtM(v.total||0)}</td><td class="td-num" style="color:var(--muted)">${pct}%</td><td class="td-num" style="color:var(--accent2)">${v.count?fmt(v.total/v.count):'—'}</td><td class="td-num">${(v.count||0).toLocaleString('es-MX')}</td></tr>`;
  }).join('');
}

// ===================== PIVOT TABLE =====================
function renderPivot(){
  const f=getFilters();
  const filteredMeses=getFilteredMeses();
  const filteredItems=getFilteredItems();
  const pivotData=getFilteredPivot();
  const searchQ=document.getElementById('pivotSearch').value.toLowerCase();
  const groupBy=document.getElementById('pivotGroupBy').value;

  // Get clients matching tipo filter and search
  let clients=RAW.clientes_info.filter(c=>{
    if(f.tipo&&c.tipo!==f.tipo)return false;
    if(searchQ&&!c.cliente.toLowerCase().includes(searchQ))return false;
    return true;
  }).map(c=>c.cliente);

  // Build lookup: cliente+mes+item -> total
  const lookup={};
  pivotData.forEach(r=>{lookup[`${r.cliente}||${r.mes}||${r.item}`]=r.total;});

  // Build columns
  let cols=[];
  if(groupBy==='item'){
    filteredItems.forEach(item=>filteredMeses.forEach(mes=>cols.push({item,mes,label:`${mes.replace('20','')}`,group:item})));
  }else{
    filteredMeses.forEach(mes=>filteredItems.forEach(item=>cols.push({item,mes,label:item,group:mes.replace('20','')})));
  }

  // Groups for header
  const groups=[];
  cols.forEach(c=>{
    if(!groups.length||groups[groups.length-1].name!==c.group)groups.push({name:c.group,count:0});
    groups[groups.length-1].count++;
  });

  // HTML
  let html=`<table class="pivot-table"><thead>`;
  // Group header row
  html+=`<tr><th class="row-header group-header">CLIENTE</th>`;
  groups.forEach(g=>html+=`<th class="group-header" colspan="${g.count}">${g.name}</th>`);
  html+=`<th class="group-header" style="position:sticky;right:0;z-index:11">TOTAL</th></tr>`;
  // Sub-header
  html+=`<tr><th class="row-header">Nombre / Tipo</th>`;
  cols.forEach(c=>html+=`<th style="min-width:90px">${groupBy==='item'?c.label:c.label}</th>`);
  html+=`<th style="position:sticky;right:0;background:var(--surface2);z-index:11">TOTAL</th></tr></thead><tbody>`;

  // Column totals accumulator
  const colTotals=new Array(cols.length).fill(0);
  let grandTotal=0;

  clients.forEach(cliente=>{
    const clientInfo=RAW.clientes_info.find(c=>c.cliente===cliente);
    const tipo=clientInfo?clientInfo.tipo:'Sin clasificar';
    const bc=TIPO_BADGE[tipo]||'b-sin';
    let rowTotal=0;
    const cells=cols.map((c,ci)=>{
      const v=lookup[`${cliente}||${c.mes}||${c.item}`]||0;
      colTotals[ci]+=v;rowTotal+=v;
      return v>0?`<span class="cell-val">${fmtM(v)}</span>`:`<span class="cell-empty">·</span>`;
    });
    grandTotal+=rowTotal;
    html+=`<tr><td class="row-label">${cliente}<span class="badge tipo-badge ${bc}">${tipo}</span></td>`;
    cells.forEach(cell=>html+=`<td>${cell}</td>`);
    html+=`<td class="row-total">${fmtM(rowTotal)}</td></tr>`;
  });

  // Total row
  html+=`<tr class="total-row"><td class="row-label">TOTAL GENERAL</td>`;
  colTotals.forEach(t=>html+=`<td class="row-total">${fmtM(t)}</td>`);
  html+=`<td class="row-total" style="color:var(--accent)">${fmtM(grandTotal)}</td></tr>`;
  html+=`</tbody></table>`;
  document.getElementById('pivotContainer').innerHTML=html;
}

// ===================== MAIN APPLY FILTERS =====================
function applyFilters(){
  const filtered=getFilteredPivot();
  renderCharts(filtered);
  renderPivot();
}


// ===================== MODAL =====================
let _lastAgg = null;
const origRenderCharts = renderCharts;

function openModal(type) {
  if (!_lastAgg) return;
  const agg = _lastAgg;
  const fmt2 = v => '$' + v.toLocaleString('es-MX', {minimumFractionDigits:2, maximumFractionDigits:2});
  const overlay = document.getElementById('modalOverlay');
  const body = document.getElementById('modalBody');
  const title = document.getElementById('modalTitle');
  overlay.classList.add('open');

  if (type === 'clientes') {
    title.textContent = 'Clientes Activos';
    const rows = Object.entries(agg.byClient)
      .map(([c,v]) => ({name:c, tipo:agg.clientTipo[c]||'', total:v.total, count:v.count}))
      .sort((a,b) => b.total - a.total);
    const bc = TIPO_BADGE;
    body.innerHTML = `
      <div class="modal-kpi-row">
        <div class="modal-kpi"><div class="mk-label">Clientes</div><div class="mk-val" style="color:var(--accent3)">${rows.length}</div></div>
        <div class="modal-kpi"><div class="mk-label">Total facturado</div><div class="mk-val" style="color:var(--accent)">${fmtM(rows.reduce((a,r)=>a+r.total,0))}</div></div>
      </div>
      <input class="modal-search" placeholder="Buscar cliente..." oninput="filterModalList(this.value, 'cliente-list')">
      <div class="modal-list" id="cliente-list">
        ${rows.map((r,i) => `
          <div class="modal-list-item">
            <div class="ml-left">
              <div class="ml-name">${i+1}. ${r.name}</div>
              <div class="ml-sub"><span class="badge ${bc[r.tipo]||'b-sin'}">${r.tipo||'Sin clasificar'}</span> · ${r.count.toLocaleString('es-MX')} registros</div>
            </div>
            <div class="ml-val">${fmtM(r.total)}</div>
          </div>`).join('')}
      </div>`;

  } else if (type === 'total') {
    title.textContent = 'Desglose del Monto Total';
    const byTipo = {};
    RAW.clientes_info.forEach(ci => { byTipo[ci.tipo] = byTipo[ci.tipo] || {total:0,clientes:0}; byTipo[ci.tipo].clientes++; });
    Object.entries(agg.byClient).forEach(([c,v]) => {
      const t = agg.clientTipo[c] || 'Sin clasificar';
      if (!byTipo[t]) byTipo[t] = {total:0,clientes:0};
      byTipo[t].total = (byTipo[t].total||0) + v.total;
    });
    const tipoRows = Object.entries(byTipo).filter(([,v])=>v.total>0).sort((a,b)=>b[1].total-a[1].total);
    const grandT = Object.values(agg.byClient).reduce((a,b)=>a+b.total,0);
    body.innerHTML = `
      <div class="modal-kpi-row">
        <div class="modal-kpi"><div class="mk-label">Gran Total</div><div class="mk-val" style="color:var(--accent)">${fmtM(grandT)}</div></div>
        <div class="modal-kpi"><div class="mk-label">Tipos</div><div class="mk-val" style="color:var(--accent2)">${tipoRows.length}</div></div>
      </div>
      <div class="modal-list">
        ${tipoRows.map(([tipo,v]) => {
          const pct = grandT ? (v.total/grandT*100).toFixed(1) : 0;
          const bc2 = TIPO_BADGE[tipo]||'b-sin';
          return `<div class="modal-list-item">
            <div class="ml-left">
              <div class="ml-name"><span class="badge ${bc2}">${tipo}</span></div>
              <div class="ml-sub">${pct}% del total</div>
            </div>
            <div class="ml-val">${fmtM(v.total)}</div>
          </div>`;
        }).join('')}
      </div>`;

  } else if (type === 'promedio') {
    title.textContent = 'Promedios por Cliente';
    const rows = Object.entries(agg.byClient)
      .map(([c,v]) => ({name:c, tipo:agg.clientTipo[c]||'', avg:v.promedio, count:v.count}))
      .sort((a,b) => b.avg - a.avg);
    const overallAvg = Object.values(agg.byClient).reduce((s,v)=>s+v.total,0) /
                       Math.max(1, Object.values(agg.byClient).reduce((s,v)=>s+v.count,0));
    body.innerHTML = `
      <div class="modal-kpi-row">
        <div class="modal-kpi"><div class="mk-label">Promedio global</div><div class="mk-val" style="color:var(--accent2)">${fmt(overallAvg)}</div></div>
        <div class="modal-kpi"><div class="mk-label">Mayor promedio</div><div class="mk-val" style="color:var(--accent4)">${fmt(rows[0]?.avg||0)}</div></div>
      </div>
      <input class="modal-search" placeholder="Buscar cliente..." oninput="filterModalList(this.value, 'avg-list')">
      <div class="modal-list" id="avg-list">
        ${rows.map((r,i) => `
          <div class="modal-list-item">
            <div class="ml-left">
              <div class="ml-name">${i+1}. ${r.name}</div>
              <div class="ml-sub"><span class="badge ${TIPO_BADGE[r.tipo]||'b-sin'}">${r.tipo||'Sin clasificar'}</span> · ${r.count.toLocaleString('es-MX')} registros</div>
            </div>
            <div class="ml-val">${fmt(r.avg)}</div>
          </div>`).join('')}
      </div>`;

  } else if (type === 'items') {
    title.textContent = 'Items por Tipo de Servicio';
    const rows = RAW.item_stats.filter(r => agg.byItem[r.item]);
    const totalItems = Object.values(agg.byItem).reduce((s,v)=>s+(v.count||0),0);
    body.innerHTML = `
      <div class="modal-kpi-row">
        <div class="modal-kpi"><div class="mk-label">Total registros</div><div class="mk-val" style="color:var(--accent3)">${totalItems.toLocaleString('es-MX')}</div></div>
        <div class="modal-kpi"><div class="mk-label">Tipos distintos</div><div class="mk-val" style="color:var(--accent4)">${Object.keys(agg.byItem).length}</div></div>
      </div>
      <div class="modal-list">
        ${Object.entries(agg.byItem).sort((a,b)=>b[1].total-a[1].total).map(([item,v],i) => {
          const color = COLORS[ALL_ITEMS.indexOf(item)%COLORS.length];
          const pct = totalItems ? ((v.count||0)/totalItems*100).toFixed(1) : 0;
          return `<div class="modal-list-item">
            <div class="ml-left">
              <div class="ml-name"><span style="display:inline-block;width:8px;height:8px;background:${color};border-radius:2px;margin-right:6px"></span>${item}</div>
